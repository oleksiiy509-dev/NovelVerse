# Supabase public frontend configuration (required on Vercel)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Comma-separated admin emails used as a frontend convenience fallback only.
# Real admin access must still be enforced by Supabase Auth/RLS policies.
VITE_ADMIN_EMAILS=admin@example.com

# Optional: enables the browser fallback link for Telegram login outside the Mini App.
# Use only the public bot username, without @.
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
