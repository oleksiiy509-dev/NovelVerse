# Supabase public frontend configuration (required on Vercel)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Server-only TTS configuration. Set these as Supabase Edge Function secrets only.
# Never prefix provider keys with VITE_ and never commit real secret values.
OPENAI_API_KEY=set-in-supabase-secrets-only
NOVELVERSE_TTS_PROVIDER=openai
NOVELVERSE_TTS_MODEL=gpt-4o-mini-tts
NOVELVERSE_TTS_DEFAULT_VOICE=alloy
NOVELVERSE_TTS_MAX_CHARS_PER_JOB=120000
NOVELVERSE_TTS_MAX_SEGMENTS_PER_JOB=600
NOVELVERSE_TTS_DAILY_USER_LIMIT=10
NOVELVERSE_TTS_PREVIEW_MAX_CHARS=1000
NOVELVERSE_TTS_TIMEOUT_MS=45000
NOVELVERSE_TTS_RETRY_COUNT=2
# Use byte-concat only for deterministic/mock/test providers. Production OpenAI MP3 merging should use an ffmpeg-compatible worker.
NOVELVERSE_AUDIO_MERGE_STRATEGY=segment-manifest
